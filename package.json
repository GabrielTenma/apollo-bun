    "@hugeicons/react": "^1.1.6",
    "@supabase/supabase-js": "^2.105.4",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "elysia": "^1.4.2",
    "evlog": "^2.17.0",
    "ink": "^3.2.0",
