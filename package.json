    "react-day-picker": "^10.0.1",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.0",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "typeorm": "^0.3.29"
