{
  "name": "apollo",
  "version": "1.0.1",
  "description": "",
  "author": "GabrielTenma",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "check": "bunx tsc --noEmit",
    "build": "",
    "compile": "bun run check && bun run lint && bun run web:build && bun run test",
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "lint": "bun x @biomejs/biome check --write src",
    "format": "bun x @biomejs/biome format --write src",
    "web:dev": "bunx vite",
    "web:build": "bunx vite build",
    "web:preview": "bunx vite preview",
    "test": "bun test --timeout 12000 --pattern src/**/*.spec.ts",
    "test:watch": "bun test --timeout 12000 --pattern src/**/*.spec.ts --watch",
    "test:cov": "bun test --timeout 12000 --pattern src/**/*.spec.ts --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
